{
  "database": "Zotero",
  "noteImportFolder": "literature",
  "pdfExportImageDPI": 120,
  "pdfExportImageFormat": "jpg",
  "pdfExportImageQuality": 90,
  "citeFormats": [
    {
      "name": "APA 7th",
      "format": "formatted-bibliography",
      "cslStyle": "American Psychological Association 7th edition"
    }
  ],
  "exportFormats": [
    {
      "name": "Literature Note",
      "outputPathTemplate": "{{citekey}}",
      "imageOutputPathTemplate": "assets/{{citekey}}",
      "imageBaseNameTemplate": "image",
      "templatePath": "Zotero_Template.md"
    }
  ],
  "citeSuggestTemplate": "[[{{citekey}}]]",
  "openNoteAfterImport": false,
  "whichNotesToOpenAfterImport": "first-imported-note",
  "shouldConcat": true
}